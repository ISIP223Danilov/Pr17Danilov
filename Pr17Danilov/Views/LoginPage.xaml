<Page x:Class="Pr17Danilov.Views.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Вход в систему">

    <Grid Background="#F0F0F0">
        <Grid Width="400" Height="350" Background="White" CornerRadius="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Космическая ложа" FontSize="24" FontWeight="Bold" 
                       HorizontalAlignment="Center" Margin="20" Foreground="#FF6B6B"/>

            <TextBlock Grid.Row="1" Text="Вход в аккаунт" FontSize="18" 
                       HorizontalAlignment="Center" Margin="10"/>

            <StackPanel Grid.Row="2" Margin="30">
                <TextBlock Text="Логин:" Margin="0,10,0,5"/>
                <TextBox Text="{Binding Login, UpdateSourceTrigger=PropertyChanged}" 
                         Height="35" BorderThickness="1"/>

                <TextBlock Text="Пароль:" Margin="0,10,0,5"/>
                <PasswordBox Name="PasswordBox" Height="35" BorderThickness="1"/>

                <TextBlock Text="{Binding ErrorMessage}" Foreground="Red" Margin="0,10"/>

                <Button Content="Войти" Command="{Binding LoginCommand}" 
                        Background="#FF6B6B" Foreground="White" FontSize="16"
                        Height="40" Margin="0,20,0,0" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>

            <Button Grid.Row="3" Content="Назад" HorizontalAlignment="Left" 
                    Margin="10" Width="80" Click="BackButton_Click" Cursor="Hand"/>
        </Grid>
    </Grid>
</Page>