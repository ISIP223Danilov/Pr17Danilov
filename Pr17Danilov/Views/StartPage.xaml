<Page x:Class="Pr17Danilov.Views.StartPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Главная - Космическая ложа">

    <Grid Background="#F0F0F0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель -->
        <Border Grid.Row="0" Background="#FF6B6B" Padding="10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Товары" Command="{Binding GoToProductsCommand}" 
                        Margin="5" Width="100" Height="35" Background="White" Cursor="Hand"/>
                <Button Content="Вход" Command="{Binding GoToLoginCommand}" 
                        Margin="5" Width="100" Height="35" Background="White" Cursor="Hand"
                        Visibility="{Binding IsAuthenticated, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Collapsed}"/>
                <Button Content="Аккаунт" Command="{Binding GoToAccountCommand}" 
                        Margin="5" Width="100" Height="35" Background="White" Cursor="Hand"
                        Visibility="{Binding IsAuthenticated, Converter={StaticResource VisibilityConverter}}"/>
            </StackPanel>
        </Border>

        <!-- Основной контент -->
        <ScrollViewer Grid.Row="1">
            <StackPanel Margin="20">
                <TextBlock Text="Добро пожаловать в Космическую ложу!" 
                           FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" Margin="20"/>

                <TextBlock Text="Запись на услуги" FontSize="22" FontWeight="Bold" Margin="0,20"/>

                <Border Background="White" CornerRadius="10" Padding="20" Margin="0,10">
                    <StackPanel>
                        <TextBlock Text="Выберите услугу:" FontSize="16" Margin="0,10"/>
                        <ComboBox ItemsSource="{Binding ServiceTypes}" 
                                  DisplayMemberPath="Name"
                                  SelectedItem="{Binding SelectedServiceType}"
                                  Height="35" Margin="0,5"/>

                        <TextBlock Text="Выберите мастера:" FontSize="16" Margin="0,20,0,10"/>
                        <ComboBox ItemsSource="{Binding Masters}" 
                                  DisplayMemberPath="FullName"
                                  SelectedItem="{Binding SelectedMaster}"
                                  Height="35" Margin="0,5"/>

                        <Button Content="Далее →" Command="{Binding BookCommand}" 
                                Background="#FF6B6B" Foreground="White" FontSize="16"
                                Height="45" Margin="0,20" Cursor="Hand"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>