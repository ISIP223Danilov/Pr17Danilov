<Page x:Class="Pr17Danilov.Views.AppointmentPage"
       xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="AppointmentPage">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Button Content="← Назад" Width="80" Margin="5" Click="Back_Click" HorizontalAlignment="Left"/>

        <TextBlock Grid.Row="1" Text="Выберите услугу:" FontWeight="Bold" Margin="5"/>
        <ComboBox x:Name="ServiceCombo" Grid.Row="2" Width="200" Margin="5" DisplayMemberPath="Name" SelectionChanged="ServiceCombo_SelectionChanged"/>

        <TextBlock Grid.Row="3" Text="Выберите дату:" FontWeight="Bold" Margin="5"/>
        <DatePicker x:Name="DatePicker" Grid.Row="4" Width="200" Margin="5" SelectedDateChanged="DatePicker_SelectedDateChanged"/>

        <TextBlock Grid.Row="5" Text="Доступное время:" FontWeight="Bold" Margin="5"/>
        <ListView x:Name="TimeListView" Grid.Row="6" Height="200" Margin="5">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Button Content="{Binding}" Width="80" Height="30" Margin="2" Click="TimeSlot_Click"/>
                </DataTemplate>
            </ListView.ItemTemplate>
            <ListView.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel/>
                </ItemsPanelTemplate>
            </ListView.ItemsPanel>
        </ListView>
    </Grid>
</Page>