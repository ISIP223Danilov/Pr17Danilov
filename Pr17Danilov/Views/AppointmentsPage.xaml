<Page x:Class="Pr17Danilov.Views.AppointmentsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Выбор времени записи">

    <Grid Background="#F0F0F0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#FF6B6B" Padding="10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="← Назад" Click="BackButton_Click" 
                        Margin="5" Width="80" Height="35" Background="White" Cursor="Hand"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="1" Margin="20">
            <TextBlock Text="Выберите дату и время" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>

            <DatePicker Name="DatePicker" SelectedDate="{Binding SelectedDate}" 
                        Margin="0,10" Height="35" Width="200" HorizontalAlignment="Left"/>

            <TextBlock Text="Доступное время:" FontSize="16" FontWeight="Bold" Margin="0,20,0,10"/>

            <ItemsControl ItemsSource="{Binding AvailableTimeSlots}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Content="{Binding}" Width="100" Height="40" Margin="5"
                                Click="TimeSlot_Click" Background="#4CAF50" Foreground="White"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock Text="{Binding ErrorMessage}" Foreground="Red" Margin="0,10"/>
        </StackPanel>
    </Grid>
</Page>