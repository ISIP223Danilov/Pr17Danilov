<Window x:Class="Pr17Danilov.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Косметическая лажа" Height="700" Width="1000"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#2C3E50" Padding="10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="LoginBtn" Content="Войти" Width="80" Margin="5" Click="LoginBtn_Click"/>
                <Button x:Name="AccountBtn" Content="Аккаунт" Width="80" Margin="5" Click="AccountBtn_Click" Visibility="Collapsed"/>
                <Button x:Name="ProductsBtn" Content="Товары" Width="80" Margin="5" Click="ProductsBtn_Click"/>
                <Button x:Name="LogoutBtn" Content="Выйти" Width="80" Margin="5" Click="LogoutBtn_Click" Visibility="Collapsed"/>
            </StackPanel>
        </Border>

        <Frame x:Name="MainFrame" Grid.Row="1" NavigationUIVisibility="Hidden"/>
    </Grid>
</Window>
